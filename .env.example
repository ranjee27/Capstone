# ═════════════════════════════════════════════════════════════
# AI Support Copilot — Full-Stack Environment Variables
# ═════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# NEVER commit the .env file — only .env.example is tracked.
# ═════════════════════════════════════════════════════════════


# ── 1. DATABASE ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=support_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── 2. REDIS ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ── 3. AUTH & JWT ────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 4. AI / LLM PROVIDERS ───────────────────────────────────
# OpenAI (for GPT-4, embeddings)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (for Claude — agent copilot, NLP)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Choose which provider to use as default: "openai" | "anthropic"
DEFAULT_LLM_PROVIDER=openai

# ── 5. EMBEDDING / VECTOR STORE ─────────────────────────────
# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=support-copilot

# Or use pgvector (no extra creds needed, uses POSTGRES_* above)
VECTOR_STORE_PROVIDER=pgvector

# RAG settings
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# ── 6. AWS (S3 uploads, SES email, etc.) ────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=support-copilot-uploads
AWS_SES_SENDER_EMAIL=noreply@yourdomain.com

# ── 7. CHANNEL INTEGRATIONS ─────────────────────────────────

# Email (SMTP for outbound)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# WhatsApp Business API (Meta)
WHATSAPP_API_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# Twilio (SMS + Voice)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_APP_ID=your_slack_app_id

# ── 8. CRM / HELPDESK INTEGRATIONS ──────────────────────────

# Salesforce
SALESFORCE_CLIENT_ID=your_sf_client_id
SALESFORCE_CLIENT_SECRET=your_sf_client_secret
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# HubSpot
HUBSPOT_API_KEY=your_hubspot_api_key

# Zendesk
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_API_TOKEN=your_zendesk_api_token
ZENDESK_EMAIL=admin@yourcompany.com

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_API_TOKEN=your_jira_api_token
JIRA_EMAIL=admin@yourcompany.com

# ── 9. VOICE / VIDEO (WebRTC) ───────────────────────────────
# TURN/STUN server for WebRTC
TURN_SERVER_URL=turn:turn.yourdomain.com:3478
TURN_SERVER_USERNAME=your_turn_username
TURN_SERVER_PASSWORD=your_turn_password

# Or use Twilio TURN (uses TWILIO_* creds above)
WEBRTC_PROVIDER=twilio

# ── 10. OBSERVABILITY ───────────────────────────────────────
# Sentry
SENTRY_DSN=https://your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── 11. KAFKA / MESSAGE QUEUE (optional) ────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=support-copilot

# Or use Redis Streams (no extra creds, uses REDIS_* above)
MESSAGE_QUEUE_PROVIDER=redis

# ── 12. CELERY / BACKGROUND TASKS ──────────────────────────
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ── 13. FRONTEND (passed to Next.js) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=AI Support Copilot
NEXT_PUBLIC_UPLOAD_MAX_SIZE=10485760

# ── 14. SECURITY ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_UPLOAD_TYPES=image/png,image/jpeg,image/webp,application/pdf
RATE_LIMIT_PER_MINUTE=60
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ── 15. APP CONFIG ──────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
